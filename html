## Файл 2: `index.html`
```html
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Шиномонтаж Колесо</title>
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#1e3c72">
</head>
<body>
    <div class="app">
        <!-- Шапка -->
        <header class="header">
            <div class="header-content">
                <h1>🛞 Шиномонтаж Колесо</h1>
                <p class="address">📍 ул. Автомобильная, 15</p>
                <p class="hours">⏰ 9:00 - 21:00</p>
            </div>
        </header>

        <!-- Основной контент -->
        <main class="main">
            <!-- Шаг 1: Услуги -->
            <section id="step-services" class="step active">
                <h2>Выберите услугу</h2>
                <div class="services-grid" id="services-list">
                    <!-- JS добавит услуги -->
                </div>
            </section>

            <!-- Шаг 2: Дата -->
            <section id="step-date" class="step">
                <h2>Выберите дату</h2>
                <div class="dates-grid" id="dates-list">
                    <!-- JS добавит даты -->
                </div>
            </section>

            <!-- Шаг 3: Время -->
            <section id="step-time" class="step">
                <h2>Выберите время</h2>
                <div class="times-grid" id="times-list">
                    <!-- JS добавит время -->
                </div>
            </section>

            <!-- Шаг 4: Подтверждение -->
            <section id="step-confirm" class="step">
                <h2>Подтверждение</h2>
                <div class="confirm-card">
                    <div class="confirm-row">
                        <span class="label">Услуга:</span>
                        <span class="value" id="confirm-service">-</span>
                    </div>
                    <div class="confirm-row">
                        <span class="label">Дата:</span>
                        <span class="value" id="confirm-date">-</span>
                    </div>
                    <div class="confirm-row">
                        <span class="label">Время:</span>
                        <span class="value" id="confirm-time">-</span>
                    </div>
                    <div class="confirm-row">
                        <span class="label">Имя:</span>
                        <span class="value" id="confirm-name">-</span>
                    </div>
                    <div class="confirm-row">
                        <span class="label">Телефон:</span>
                        <span class="value" id="confirm-phone">-</span>
                    </div>
                </div>
                <button class="btn btn-primary" id="confirm-btn">✅ Подтвердить запись</button>
                <button class="btn btn-secondary" id="back-btn">← Назад</button>
            </section>

            <!-- Успех -->
            <section id="step-success" class="step">
                <div class="success-card">
                    <div class="success-icon">✅</div>
                    <h2>Запись подтверждена!</h2>
                    <p>Мы отправили уведомление в Telegram</p>
                    <p class="booking-detail" id="success-detail"></p>
                    <button class="btn btn-primary" id="new-booking-btn">➕ Новая запись</button>
                </div>
            </section>
        </main>

        <!-- Нижняя панель -->
        <footer class="footer">
            <button class="nav-btn" id="nav-my">
                📋 Мои записи
            </button>
            <button class="nav-btn" id="nav-home">
                🏠 Главная
            </button>
        </footer>
    </div>

    <!-- Telegram Web App SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="script.js"></script>
</body>
</html>
